---

import '../styles/components/project-card.scss';

interface Props {
  slug: string;
  title: string;
  category: string;
  description: string;
  thumbnail: string;
  year: number;
  status: 'planned' | 'released' | 'wip' | 'jam' | 'archived';
}

const { slug, title, category, description, thumbnail, year, status } = Astro.props;

const statusLabels: Record<string, string> = {
  planned: 'Planned',
  released: 'Released',
  wip: 'WIP',
  jam: 'Jam',
  archived: 'Archived',
};

const categoryLabels: Record<string, string> = {
  game: 'Game',
  music: 'Music',
  software: 'Software',
  poem: 'Poem',
  art: 'Art',
  collab: 'Collaboration',
  other: 'Other',
};
---

<a href={`/projetos/${slug}`} class="project-card" data-category={category} data-status={status}>
  <div class="project-thumbnail">
    <img src={thumbnail} alt={title} />
    <div class="project-badges">
      <span class="badge category">{categoryLabels[category]}</span>
      <span class={`badge status ${status}`}>{statusLabels[status]}</span>
    </div>
  </div>
  <div class="project-info">
    <h3 class="project-title">{title}</h3>
    <p class="project-description">{description}</p>
    <p class="project-year">{year}</p>
  </div>
</a>
