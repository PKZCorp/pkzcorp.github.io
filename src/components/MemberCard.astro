---
import '../styles/components/member-card.scss';

interface Props {
  slug: string;
  name: string;
  avatar: string;
  tagline: string;
  skills: string[];
}

const { slug, name, avatar, tagline, skills } = Astro.props;
---

<a href={`/membros/${slug}`} class="member-card">
  <div class="member-avatar">
    <img src={avatar} alt={name} />
  </div>
  <div class="member-info">
    <h3 class="member-name">{name}</h3>
    <p class="member-tagline">{tagline}</p>
    <div class="member-skills">
      {skills.slice(0, 3).map(skill => (
        <span class="skill-tag">{skill}</span>
      ))}
      {skills.length > 3 && <span class="skill-more">+{skills.length - 3}</span>}
    </div>
  </div>
</a>
