---
import { CodeXml, ExternalLink, House, Info, Mail, Sparkles, SquareKanban, Users } from '@lucide/astro';
import { siBandlab, siDiscord, siGithub, siInstagram, siPinterest, siReddit, siRoblox, siSoundcloud, siSpotify, siSteam, siTiktok, siX, siYoutube } from 'simple-icons';

const ICONS: Record<string, any> = {
	home: House,
	info: Info,
	users: Users,
	project: SquareKanban,
	spark: Sparkles,
	mail: Mail,
	repo: CodeXml,
	external: ExternalLink,
	// Social media: use external icon for unknown services
	github: siGithub,
	instagram: siInstagram,
	pinterest: siPinterest,
	discord: siDiscord,
	bandlab: siBandlab,
	steam: siSteam,
	spotify: siSpotify,
	reddit: siReddit,
	roblox: siRoblox,
	itch: ExternalLink,
	soundcloud: siSoundcloud,
	tiktok: siTiktok,
	twitter: siX,
	x: siX,
	youtube: siYoutube,
};

type IconName = keyof typeof ICONS;

interface Props {
	name?: IconName | string;
	size?: number | string;
	class?: string;
}

const { name = 'home', size = 16, class: cls = '' } = Astro.props as Props;
const IconComponent = ICONS[name] || ExternalLink;
const isSimpleIcon = name in ICONS && typeof IconComponent === 'object' && 'path' in IconComponent;

function getSimpleIconFill(name: string, hex: string) {
	const normalized = hex.replace('#', '');
	if (name === 'github') {
		return '#ffffff';
	}
	if (normalized.toLowerCase() === '000000') {
		return 'currentColor';
	}
	const red = Number.parseInt(normalized.slice(0, 2), 16);
	const green = Number.parseInt(normalized.slice(2, 4), 16);
	const blue = Number.parseInt(normalized.slice(4, 6), 16);
	const luminance = 0.2126 * red + 0.7152 * green + 0.0722 * blue;

	return luminance < 10 ? 'currentColor' : `#${normalized}`;
}
---

{
	IconComponent === ExternalLink ? (
		<IconComponent size={size} class={cls} aria-hidden="true" />
	) : isSimpleIcon ? (
		<svg
			viewBox="0 0 24 24"
			width={size}
			height={size}
			class={cls}
			aria-hidden="true"
			role="img"
			fill={getSimpleIconFill(name, IconComponent.hex)}
			focusable="false"
		>
			<title>{IconComponent.title}</title>
			<path d={IconComponent.path} />
		</svg>
	) : (
		<IconComponent size={size} class={cls} aria-hidden="true" />
	)
}

