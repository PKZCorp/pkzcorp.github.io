---
import { CodeXml, ExternalLink, House, Info, Mail, Sparkles, SquareKanban, Users } from '@lucide/astro';

const ICONS: Record<string, any> = {
	home: House,
	info: Info,
	users: Users,
	project: SquareKanban,
	spark: Sparkles,
	mail: Mail,
	repo: CodeXml,
	external: ExternalLink,
	// Social media: use external icon for unknown services
	github: ExternalLink,
	itch: ExternalLink,
	soundcloud: ExternalLink,
};

type IconName = keyof typeof ICONS;

interface Props {
	name?: IconName | string;
	size?: number | string;
	class?: string;
}

const { name = 'home', size = 16, class: cls = '' } = Astro.props as Props;
const IconComponent = ICONS[name] || ExternalLink;
---

<IconComponent size={size} class={cls} aria-hidden="true" />

