---
// src/layouts/Base.astro
// Main layout for all pages - imports global and layout styles
// Supports i18n with proper locale detection

import { getLangFromUrl, useTranslations, getNavLinks, getIconForNavItem } from '../i18n/utils';
import '../styles/global.scss';
import '../styles/layout.scss';
import SiteLogo from '../components/SiteLogo.astro';
import Icon from '../components/Icon.astro';
import LanguagePicker from '../components/LanguagePicker.astro';
import ogImage from '../assets/logo/logo-default.png';

interface Props {
  title?: string;
  description?: string;
}

const { title = "PKZCorp", description = "Creative tech collective" } = Astro.props;

// Get current locale from URL
const currentLocale = Astro.currentLocale || 'pt-br';
const langAttribute = currentLocale === 'pt-br' ? 'pt-BR' : 'en';

// Get translations
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const navLinks = getNavLinks(lang);
---

<!doctype html>
<html lang={langAttribute}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content="PKZCorp" />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage.src} />
    <title>{title}</title>
    
    <!-- Favicons and Web Manifest -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#000000" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    
    <!-- Import Google Fonts (defined in brand workbook) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script src="/js/nav.js" defer></script>
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="google-site-verification" content="AN3jecaR5FK1x2_7CiJ-SfVShmjMh8pCz5PsYhAY5mE" />
  </head>

  <body>
    <!-- Header / Navigation -->
    <header class="header">
      <div class="container-full header-content">
        <div class="logo-area">
          <h1 class="logo"><SiteLogo /></h1>
        </div>
        <button class="menu-button" aria-expanded="false" aria-controls="main-nav" id="menu-button">☰</button>
        <nav class="nav" id="main-nav" aria-hidden="true">
          {navLinks.map(link => (
            <a href={link.href}>
              <Icon name={getIconForNavItem(link.key)} size={18} class="nav-icon" aria-hidden="true"/>
              {link.label}
            </a>
          ))}
          <LanguagePicker />
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main class="main">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="container-full">
          <p>{t('footer.copyright')}</p>
          <div class="footer-social">
            <a href="https://github.com/PKZCorp/pkzcorp.github.io" aria-label="Repository" class="social-link"><Icon name="repo" size={20} /></a>
            <a href="mailto:pedrokszcorp@gmail.com" aria-label="Email" class="social-link"><Icon name="mail" size={20} /></a>
          </div>
      </div>
    </footer>
  </body>
</html>
