---
// src/layouts/Base.astro
// Main layout for all pages - imports global and layout styles
// Supports i18n with proper locale detection

import { getRelativeLocaleUrl } from 'astro:i18n';
import '../styles/global.scss';
import '../styles/layout.scss';
import SiteLogo from '../components/SiteLogo.astro';
import Icon from '../components/Icon.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title = "PKZCorp", description = "Creative tech collective" } = Astro.props;

// Get current locale from URL
const currentLocale = Astro.currentLocale || 'pt-br';
const langAttribute = currentLocale === 'pt-br' ? 'pt-BR' : 'en';

// Navigation labels based on locale
const navLabels = currentLocale === 'pt-br' 
  ? {
      home: 'Home',
      about: 'Sobre',
      members: 'Membros',
      projects: 'Projetos',
      jams: 'Jams',
      contact: 'Contato'
    }
  : {
      home: 'Home',
      about: 'About',
      members: 'Members',
      projects: 'Projects',
      jams: 'Jams',
      contact: 'Contact'
    };

// Nav link routes based on locale
const navLinks = currentLocale === 'pt-br'
  ? [
      { href: getRelativeLocaleUrl('pt-br', ''), label: navLabels.home },
      { href: getRelativeLocaleUrl('pt-br', 'sobre'), label: navLabels.about },
      { href: getRelativeLocaleUrl('pt-br', 'membros'), label: navLabels.members },
      { href: getRelativeLocaleUrl('pt-br', 'projetos'), label: navLabels.projects },
      { href: getRelativeLocaleUrl('pt-br', 'jams'), label: navLabels.jams },
      { href: getRelativeLocaleUrl('pt-br', 'contato'), label: navLabels.contact }
    ]
  : [
      { href: getRelativeLocaleUrl('en', ''), label: navLabels.home },
      { href: getRelativeLocaleUrl('en', 'sobre'), label: navLabels.about },
      { href: getRelativeLocaleUrl('en', 'membros'), label: navLabels.members },
      { href: getRelativeLocaleUrl('en', 'projetos'), label: navLabels.projects },
      { href: getRelativeLocaleUrl('en', 'jams'), label: navLabels.jams },
      { href: getRelativeLocaleUrl('en', 'contato'), label: navLabels.contact }
    ];
---

<!doctype html>
<html lang={langAttribute}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    
    <!-- Favicons and Web Manifest -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#000000" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    
    <!-- Import Google Fonts (defined in brand workbook) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script src="/js/nav.js" defer></script>
  </head>

  <body>
    <!-- Header / Navigation -->
    <header class="header">
      <div class="container header-content">
        <div class="logo-area">
          <h1 class="logo"><SiteLogo /></h1>
        </div>
        <button class="menu-button" aria-expanded="false" aria-controls="main-nav" id="menu-button">☰</button>
        <nav class="nav" id="main-nav" aria-hidden="true">
          {navLinks.map(link => (
            <a href={link.href}>
              <Icon name={link.label === 'Home' || link.label === navLabels.home ? 'home' : link.label === navLabels.about || link.label === 'About' ? 'info' : link.label === navLabels.members || link.label === 'Members' ? 'users' : link.label === navLabels.projects || link.label === 'Projects' ? 'project' : link.label === navLabels.jams || link.label === 'Jams' ? 'spark' : 'mail'} size={18} class="nav-icon" aria-hidden="true"/>
              {link.label}
            </a>
          ))}
          <a href={currentLocale === 'pt-br' ? getRelativeLocaleUrl('en', '') : getRelativeLocaleUrl('pt-br', '')}>
            {currentLocale === 'pt-br' ? 'EN' : 'PT'}
          </a>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main class="main">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="container">
          <p>&copy; 2026 PKZCorp. All rights reserved.</p>
          <div class="footer-social">
            <a href="https://github.com/PKZCorp/pkzcorp.github.io" aria-label="Repository" class="social-link"><Icon name="repo" size={20} /></a>
            <a href="mailto:pedrokszcorp@gmail.com" aria-label="Email" class="social-link"><Icon name="mail" size={20} /></a>
          </div>
      </div>
    </footer>
  </body>
</html>
