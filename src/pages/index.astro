---
// src/pages/index.astro
// Home page (Portuguese) - entry point for the site

import { getRelativeLocaleUrl } from 'astro:i18n';
import Base from '../layouts/Base.astro';
import '../styles/components/hero.scss';
import '../styles/components/buttons.scss';
import '../styles/components/sections.scss';
---

<Base title="PKZCorp — Coletivo Criativo">
  <div class="container-full">
    <section class="hero">
      <h1>Bem-vindo ao PKZCorp</h1>
      <p>Um coletivo criativo de tecnologia reunindo software e arte.</p>
      <div class="btn-group">
        <a href={getRelativeLocaleUrl('pt-br', 'membros')} class="btn btn-primary">Conheça o Time</a>
        <a href={getRelativeLocaleUrl('pt-br', 'projetos')} class="btn btn-secondary">Veja os Projetos</a>
      </div>
    </section>
  </div>

  <div class="container">
    <section class="section">
      <h2>Projetos Destacados</h2>
      <p>Em breve — os projetos serão listados aqui.</p>
    </section>

    <section class="section">
      <h2>Jams Ativos</h2>
      <p>Em breve — os desafios criativos ativos aparecerão aqui.</p>
    </section>
  </div>
</Base>
