---
// src/pages/index.astro
// Home page - entry point for the site

import { useBaseUrl } from '../lib/useBaseUrl';
import Base from '../layouts/Base.astro';
import '../styles/components/hero.scss';
import '../styles/components/buttons.scss';
import '../styles/components/sections.scss';
---

<Base title="PKZCorp — Creative Collective">
  <section class="hero">
    <h1>Welcome to PKZCorp</h1>
    <p>A creative tech collective bringing software and art together.</p>
    <div class="btn-group">
      <a href={useBaseUrl('/membros')} class="btn btn-primary">Meet the Team</a>
      <a href={useBaseUrl('/projetos')} class="btn btn-secondary">View Projects</a>
    </div>
  </section>

  <section class="section">
    <h2>Featured Projects</h2>
    <p>Coming soon — projects will be listed here.</p>
  </section>

  <section class="section">
    <h2>Active Jams</h2>
    <p>Coming soon — active creative challenges will appear here.</p>
  </section>
</Base>
