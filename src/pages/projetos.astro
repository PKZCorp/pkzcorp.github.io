---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import '../styles/pages/projects.scss';

const projects = await getCollection('projects');

const categoryFilter = Astro.url.searchParams.get('category');
const statusFilter = Astro.url.searchParams.get('status');

const filteredProjects = projects.filter(project => {
  if (categoryFilter && project.data.category !== categoryFilter) return false;
  if (statusFilter && project.data.status !== statusFilter) return false;
  return true;
});

const sortedProjects = filteredProjects.sort((a, b) => b.data.year - a.data.year);

const categories = Array.from(new Set(projects.map(p => p.data.category))).sort();
const statuses = Array.from(new Set(projects.map(p => p.data.status))).sort();

const categoryLabels: Record<string, string> = {
  game: 'Games',
  music: 'Music',
  software: 'Software',
  poem: 'Poems',
  art: 'Art',
  collab: 'Collaboration',
  other: 'Other',
};

const statusLabels: Record<string, string> = {
  released: 'Released',
  wip: 'WIP',
  jam: 'Jam',
  archived: 'Archived',
};
---

<Base title="Projetos — PKZCorp" description="Explore os projetos da PKZCorp">
  <div class="container">
    <h1>Projetos</h1>
    <p class="intro-text">Uma coleção de trabalhos criativos e técnicos</p>

    <div class="filters">
      <div class="filter-group">
        <label>Categoria</label>
        <div class="filter-buttons">
          <a
            href="/projetos"
            class={`filter-btn ${!categoryFilter ? 'active' : ''}`}
          >
            Todas
          </a>
          {categories.map(cat => (
            <a
              href={`/projetos?category=${cat}${statusFilter ? `&status=${statusFilter}` : ''}`}
              class={`filter-btn ${categoryFilter === cat ? 'active' : ''}`}
            >
              {categoryLabels[cat]}
            </a>
          ))}
        </div>
      </div>

      <div class="filter-group">
        <label>Status</label>
        <div class="filter-buttons">
          <a
            href="/projetos"
            class={`filter-btn ${!statusFilter ? 'active' : ''}`}
          >
            Todos
          </a>
          {statuses.map(status => (
            <a
              href={`/projetos?status=${status}${categoryFilter ? `&category=${categoryFilter}` : ''}`}
              class={`filter-btn ${statusFilter === status ? 'active' : ''}`}
            >
              {statusLabels[status]}
            </a>
          ))}
        </div>
      </div>
    </div>

    {sortedProjects.length > 0 ? (
      <div class="projects-grid">
        {sortedProjects.map(project => (
          <ProjectCard
            slug={project.data.slug}
            title={project.data.title}
            category={project.data.category}
            description={project.data.description}
            thumbnail={project.data.thumbnail}
            year={project.data.year}
            status={project.data.status}
          />
        ))}
      </div>
    ) : (
      <div class="no-results">
        <p>Nenhum projeto encontrado com esses filtros.</p>
      </div>
    )}
  </div>
</Base>
