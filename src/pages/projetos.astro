---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import '../styles/pages/projects.scss';
import { initProjectSearch } from '../scripts/projectSearch';
import { initFilterDropdowns } from '../scripts/filterDropdowns';

const projects = await getCollection('projects');

const categoryFilter = Astro.url.searchParams.get('category');
const statusFilter = Astro.url.searchParams.get('status');

const filteredProjects = projects.filter(project => {
  if (categoryFilter && project.data.category !== categoryFilter) return false;
  if (statusFilter && project.data.status !== statusFilter) return false;
  return true;
});

const sortedProjects = filteredProjects.sort((a, b) => b.data.year - a.data.year);

const categories = Array.from(new Set(projects.map(p => p.data.category))).sort();
const statuses = Array.from(new Set(projects.map(p => p.data.status))).sort();

const categoryLabels: Record<string, string> = {
  game: 'Jogos',
  music: 'Música',
  software: 'Software',
  poem: 'Poesias',
  art: 'Arte',
  collab: 'Colaboração',
  other: 'Outros',
};

const statusLabels: Record<string, string> = {
  planned: 'Planejado',
  released: 'Lançado',
  wip: 'Em Desenvolvimento',
  jam: 'Game Jam',
  archived: 'Arquivado',
};
---

<Base title="Projetos — PKZCorp" description="Explore os projetos da PKZCorp">
  <div class="container-wide">
    <h1>Projetos</h1>
    <p class="intro-text">Uma coleção de trabalhos criativos e técnicos</p>

    <div class="search-bar">
      <input
        type="text"
        id="project-search"
        placeholder="Buscar projetos por título ou descrição..."
        class="search-input"
      />
    </div>

    <div class="filters">
      <select id="category-filter" class="filter-select">
        <option value="">Todas as Categorias</option>
        {categories.map(cat => (
          <option value={cat} selected={categoryFilter === cat}>
            {categoryLabels[cat]}
          </option>
        ))}
      </select>

      <select id="status-filter" class="filter-select">
        <option value="">Todos os Status</option>
        {statuses.map(status => (
          <option value={status} selected={statusFilter === status}>
            {statusLabels[status]}
          </option>
        ))}
      </select>
    </div>

    {sortedProjects.length > 0 ? (
      <div class="projects-grid">
        {sortedProjects.map(project => (
          <ProjectCard
            slug={project.data.slug}
            title={project.data.title}
            category={project.data.category}
            description={project.data.description}
            thumbnail={project.data.thumbnail}
            year={project.data.year}
            status={project.data.status}
          />
        ))}
      </div>
    ) : (
      <div class="no-results">
        <p>Nenhum projeto encontrado com esses filtros.</p>
      </div>
    )}
    <div id="search-no-results" class="no-results" style="display: none;">
      <p>Nenhum projeto corresponde à sua busca.</p>
    </div>
    <div id="filter-no-results" class="no-results" style="display: none;">
      <p>Nenhum projeto encontrado com esses filtros.</p>
    </div>
  </div>
</Base>

<script>
  import { initProjectSearch } from '../scripts/projectSearch';
  import { initFilterDropdowns } from '../scripts/filterDropdowns';

  initProjectSearch();
  initFilterDropdowns();
</script>
