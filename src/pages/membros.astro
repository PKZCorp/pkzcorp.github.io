---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import MemberCard from '../components/MemberCard.astro';
import '../styles/pages/members.scss';

const locale: 'en' | 'pt-br' = Astro.currentLocale === 'en' ? 'en' : 'pt-br';
const members = await getCollection('members');

const getDisplayName = (member: typeof members[number]) => (
  locale === 'en' && member.data.name_en ? member.data.name_en : member.data.name
);

const getDisplayTagline = (member: typeof members[number]) => (
  locale === 'en' && member.data.tagline_en ? member.data.tagline_en : member.data.tagline
);

const getDisplaySkills = (member: typeof members[number]) => (
  locale === 'en' && member.data.skills_en ? member.data.skills_en : member.data.skills
);

const sortedMembers = members.sort((a, b) => getDisplayName(a).localeCompare(getDisplayName(b), locale === 'pt-br' ? 'pt-BR' : 'en'));
---

<Base title="Membros — PKZCorp" description="Conheça os membros da PKZCorp">
  <div class="container-wide">
    <h1>Membros</h1>
    <p class="intro-text">Conheça o time criativo por trás da PKZCorp</p>

    <div class="members-grid">
      {sortedMembers.map(member => (
        <MemberCard
          slug={member.data.slug}
          name={getDisplayName(member)}
          avatar={member.data.avatar}
          tagline={getDisplayTagline(member)}
          skills={getDisplaySkills(member)}
          locale={locale}
        />
      ))}
    </div>
  </div>
</Base>
