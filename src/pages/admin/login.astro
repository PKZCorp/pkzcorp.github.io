---
import Base from '../../layouts/Base.astro';
import '../../styles/pages/admin.scss';
---

<Base title="Admin Login — PKZCorp" description="PKZCorp member admin login">
  <div class="container admin-page">
    <section class="admin-card">
      <h1>Member Login</h1>
      <p class="admin-copy">Use your email to receive a magic login link.</p>

      <form id="admin-login-form" class="admin-form">
        <label for="admin-email">Email</label>
        <input id="admin-email" name="email" type="email" autocomplete="email" required />

        <button type="submit" class="admin-btn">Send magic link</button>
      </form>

      <p id="admin-login-feedback" class="admin-feedback" aria-live="polite"></p>
    </section>
  </div>

  <script type="module">
    import '../../scripts/admin/login';
  </script>
</Base>
