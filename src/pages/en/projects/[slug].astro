---
import { Image } from 'astro:assets';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Icon from '../../../components/Icon.astro';
import '../../../styles/pages/project-slug.scss';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const locale = Astro.currentLocale || 'en';
const title = project.data.title_en ?? project.data.title;
const description = project.data.description_en ?? project.data.description;
const { category, year, members, thumbnail, images, links, status, tags } = project.data;

const imagesGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/*.{jpeg,jpg,png,gif}');
if (!imagesGlob[thumbnail]) throw new Error(`"${thumbnail}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif}"`);

const categoryLabels: Record<string, string> = {
  game: 'Game',
  music: 'Music',
  software: 'Software',
  poem: 'Poem',
  art: 'Art',
  collab: 'Collaboration',
  other: 'Other',
};

const statusLabels: Record<string, string> = {
  released: 'Released',
  wip: 'WIP',
  jam: 'Jam',
  archived: 'Archived',
};
---

<Base title={`${title} — PKZCorp`} description={description}>
  <div class="container">
    <div class="project-hero">
      <Image src={imagesGlob[thumbnail]()} alt={title} class="hero-image" inferSize />
      <div class="hero-overlay">
        <div class="hero-badges">
          <span class="badge category">{categoryLabels[category]}</span>
          <span class={`badge status ${status}`}>{statusLabels[status]}`}</span>
        </div>
      </div>
    </div>

    <div class="project-header">
      <h1>{title}</h1>
      <p class="project-year">{year}</p>
      {links && (
        <div class="project-links">
          {Object.entries(links).map(([key, url]) => (
            <a href={url} target="_blank" rel="noopener noreferrer" class="link-btn">
              <Icon name={key} size={18} />
              {key.charAt(0).toUpperCase() + key.slice(1)}
            </a>
          ))}
        </div>
      )}
    </div>

    <div class="project-content">
      <section class="description-section">
        <h2>About</h2>
        <p>{description}</p>
      </section>

      {members && members.length > 0 && (
        <section class="members-section">
          <h2>Members</h2>
          <div class="members-list">
            {members.map(memberSlug => (
              <a href={getRelativeLocaleUrl('en', `members/${memberSlug}`)} class="member-link">
                {memberSlug}
              </a>
            ))}
          </div>
        </section>
      )}

      {tags && tags.length > 0 && (
        <section class="tags-section">
          <h2>Tags</h2>
          <div class="tags-list">
            {tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </section>
      )}

      {images && images.length > 0 && (
        <section class="images-section">
          <h2>Gallery</h2>
          <div class="images-grid">
            {images.map(img => (
              <Image src={imagesGlob[img]()} alt={title} class="gallery-image" inferSize />
            ))}
          </div>
        </section>
      )}
    </div>

    <div class="back-link">
      <a href={getRelativeLocaleUrl('en', 'projects')}>← Back to projects</a>
    </div>
  </div>
</Base>
