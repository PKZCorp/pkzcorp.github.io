---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import MemberCard from '../../components/MemberCard.astro';
import '../../styles/pages/members.scss';

const members = await getCollection('members');
const sortedMembers = members.sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<Base title="Members — PKZCorp" description="Meet the PKZCorp team">
  <div class="container">
    <h1>Members</h1>
    <p class="intro-text">Meet the creative minds behind PKZCorp</p>

    <div class="members-grid">
      {sortedMembers.map(member => (
        <MemberCard
          slug={member.data.slug}
          name={member.data.name}
          avatar={member.data.avatar}
          tagline={member.data.tagline}
          skills={member.data.skills}
        />
      ))}
    </div>
  </div>
</Base>
