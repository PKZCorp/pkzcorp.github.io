---
// src/pages/en/index.astro
// Home page (English) - entry point for the site

import { getRelativeLocaleUrl } from 'astro:i18n';
import Base from '../../layouts/Base.astro';
import '../../styles/components/hero.scss';
import '../../styles/components/buttons.scss';
import '../../styles/components/sections.scss';
---

<Base title="PKZCorp — Creative Collective">
  <section class="hero">
    <h1>Welcome to PKZCorp</h1>
    <p>A creative tech collective bringing software and art together.</p>
    <div class="btn-group">
      <a href={getRelativeLocaleUrl('en', 'membros')} class="btn btn-primary">Meet the Team</a>
      <a href={getRelativeLocaleUrl('en', 'projetos')} class="btn btn-secondary">View Projects</a>
    </div>
  </section>

  <div class="container">
    <section class="section">
      <h2>Featured Projects</h2>
      <p>Coming soon — projects will be listed here.</p>
    </section>

    <section class="section">
      <h2>Active Jams</h2>
      <p>Coming soon — active creative challenges will appear here.</p>
    </section>
  </div>
</Base>
