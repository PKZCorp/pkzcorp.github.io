---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Icon from '../../../components/Icon.astro';
import '../../../styles/pages/member-slug.scss';

export async function getStaticPaths() {
  const members = await getCollection('members');
  return members.map(member => ({
    params: { slug: member.data.slug },
    props: { member },
  }));
}

const { member } = Astro.props;
const locale: 'en' | 'pt-br' = Astro.currentLocale === 'en' ? 'en' : 'pt-br';

const name = locale === 'en' && member.data.name_en ? member.data.name_en : member.data.name;
const tagline = locale === 'en' && member.data.tagline_en ? member.data.tagline_en : member.data.tagline;
const bio = locale === 'en' && member.data.bio_en ? member.data.bio_en : member.data.bio;
const avatar = member.data.avatar;
const skills = locale === 'en' && member.data.skills_en ? member.data.skills_en : member.data.skills;
const links = member.data.links;
const productions = member.data.productions?.map(prod => ({
  ...prod,
  title: locale === 'en' && prod.title_en ? prod.title_en : prod.title,
  description: locale === 'en' && prod.description_en ? prod.description_en : prod.description,
}));
const backLink = getRelativeLocaleUrl(locale, locale === 'pt-br' ? 'membros' : 'members');
---

<Base title={`${name} — PKZCorp`} description={tagline}>
  <div class="container">
    <div class="member-hero">
      <img src={avatar} alt={name} class="hero-avatar" />
      <div class="hero-info">
        <h1>{name}</h1>
        <p class="tagline">{tagline}</p>
        {links && (
          <div class="member-links">
            {Object.entries(links).map(([key, url]) => (
              <a href={url} target="_blank" rel="noopener noreferrer" aria-label={key}>
                <Icon name={key} size={20} />
              </a>
            ))}
          </div>
        )}
      </div>
    </div>

    <div class="member-content">
      <section class="bio-section">
        <h2>About</h2>
        <p>{bio}</p>
      </section>

      {skills && skills.length > 0 && (
        <section class="skills-section">
          <h2>Skills</h2>
          <div class="skills-list">
            {skills.map(skill => (
              <span class="skill-badge">{skill}</span>
            ))}
          </div>
        </section>
      )}

      {productions && productions.length > 0 && (
        <section class="productions-section">
          <h2>Productions</h2>
          <div class="productions-list">
            {productions.map(prod => (
              <div class="production-item">
                <a href={prod.url} target="_blank" rel="noopener noreferrer" class="production-link">
                  <strong>{prod.title}</strong>
                  <span class="production-meta">{prod.type} • {prod.year}</span>
                </a>
                {prod.description && (
                  <p class="production-description">{prod.description}</p>
                )}
              </div>
            ))}
          </div>
        </section>
      )}
    </div>

    <div class="back-link">
      <a href={backLink}>{locale === 'pt-br' ? '← Voltar para membros' : '← Back to members'}</a>
    </div>
  </div>
</Base>
