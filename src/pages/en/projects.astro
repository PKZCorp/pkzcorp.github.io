---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import '../../styles/pages/projects.scss';
import { initProjectSearch } from '../../scripts/projectSearch';
import { initFilterDropdowns } from '../../scripts/filterDropdowns';

const projects = await getCollection('projects');

const categoryFilter = Astro.url.searchParams.get('category');
const statusFilter = Astro.url.searchParams.get('status');

const filteredProjects = projects.filter(project => {
  if (categoryFilter && project.data.category !== categoryFilter) return false;
  if (statusFilter && project.data.status !== statusFilter) return false;
  return true;
});

const sortedProjects = filteredProjects.sort((a, b) => b.data.year - a.data.year);

const categories = Array.from(new Set(projects.map(p => p.data.category))).sort();
const statuses = Array.from(new Set(projects.map(p => p.data.status))).sort();

const categoryLabels: Record<string, string> = {
  game: 'Games',
  music: 'Music',
  software: 'Software',
  poem: 'Poems',
  art: 'Art',
  collab: 'Collaboration',
  other: 'Other',
};

const statusLabels: Record<string, string> = {
  released: 'Released',
  wip: 'WIP',
  jam: 'Jam',
  archived: 'Archived',
};
---

<Base title="Projects — PKZCorp" description="Explore PKZCorp projects">
  <div class="container-wide">
    <h1>Projects</h1>
    <p class="intro-text">A collection of creative and technical works</p>

    <div class="search-bar">
      <input
        type="text"
        id="project-search"
        placeholder="Search projects by title or description..."
        class="search-input"
      />
    </div>

    <div class="filters">
      <select id="category-filter" class="filter-select">
        <option value="">All Categories</option>
        {categories.map(cat => (
          <option value={cat} selected={categoryFilter === cat}>
            {categoryLabels[cat]}
          </option>
        ))}
      </select>

      <select id="status-filter" class="filter-select">
        <option value="">All Statuses</option>
        {statuses.map(status => (
          <option value={status} selected={statusFilter === status}>
            {statusLabels[status]}
          </option>
        ))}
      </select>
    </div>

    {sortedProjects.length > 0 ? (
      <div class="projects-grid">
        {sortedProjects.map(project => (
          <ProjectCard
            slug={project.data.slug}
            title={project.data.title}
            category={project.data.category}
            description={project.data.description}
            thumbnail={project.data.thumbnail}
            year={project.data.year}
            status={project.data.status}
          />
        ))}
      </div>
    ) : (
      <div class="no-results">
        <p>No projects found with those filters.</p>
      </div>
    )}
    <div id="search-no-results" class="no-results" style="display: none;">
      <p>No projects match your search.</p>
    </div>
    <div id="filter-no-results" class="no-results" style="display: none;">
      <p>No projects found with those filters.</p>
    </div>
  </div>
</Base>

<script>
  import { initProjectSearch } from '../../scripts/projectSearch';
  import { initFilterDropdowns } from '../../scripts/filterDropdowns';

  initProjectSearch();
  initFilterDropdowns();
</script>

